# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies
node_modules

# Build output
dist
dist-ssr
*.local

# Env files (keep *.example templates)
# Ignore all env files in apps/* directories
apps/*/.env
apps/*/.env.local
apps/*/.env.production
apps/*/.env.*.local

# But keep example files
!apps/*/.env.example
!apps/*/.env.local.example
!apps/*/.env.production.example

# Portfolio PNGs under docs/screenshots/ are committed.
# Ignore capture temp + webm; ignore mp4 unless intentionally committing video
# (README uses Loom for the public walkthrough by default).
docs/screenshots/_video-tmp/
docs/screenshots/*.webm
docs/screenshots/*.mp4

# Test coverage
coverage
*.lcov

# Playwright
test-results/
playwright-report/
blob-report/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.vercel
.env*
