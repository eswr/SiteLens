{
  "name": "sitelens",
  "private": true,
  "version": "0.1.0",
  "description": "SiteLens — geospatial planning intelligence platform (monorepo: web + API + shared)",
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20 <21",
    "npm": ">=10"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run build -w packages/shared --if-present",
    "dev": "npm run build:shared && concurrently -k -n shared,api,web -c cyan,magenta,green \"npm run dev:shared\" \"npm run dev -w apps/api\" \"npm run dev -w apps/web\"",
    "dev:web": "npm run build:shared && npm run dev -w apps/web",
    "dev:web:prod-api": "bash scripts/dev-web-prod-api.sh",
    "dev:shared": "npm run dev -w packages/shared",
    "dev:api": "npm run build:shared && npm run dev -w apps/api",
    "build": "npm run build:shared && npm run build -w apps/api && npm run build -w apps/web --if-present",
    "build:web": "npm run build:shared && npm run build -w apps/web",
    "build:api": "npm run build:shared && npm run build -w apps/api",
    "build:shared": "npm run build -w packages/shared",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:up": "docker compose -f infra/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/docker-compose.yml down",
    "db:reset": "npm run db:reset -w apps/api",
    "db:migrate": "npm run db:migrate -w apps/api",
    "db:migrate:check": "npm run db:migrate:check -w apps/api",
    "db:migrate:prod": "npm run db:migrate:prod -w apps/api",
    "db:migrate:check:prod": "npm run db:migrate:check:prod -w apps/api",
    "db:codegen": "npm run db:codegen -w apps/api",
    "db:seed": "npm run db:seed -w apps/api",
    "db:seed:billing": "npm run db:seed:billing -w apps/api",
    "db:seed:billing:prod": "npm run db:seed:billing:prod -w apps/api",
    "ingest:geojson": "npm run ingest:geojson -w apps/api",
    "ingest:geojson:prod": "npm run ingest:geojson:prod -w apps/api",
    "cache:clear": "npm run cache:clear -w apps/api",
    "cache:clear:prod": "npm run cache:clear:prod -w apps/api",
    "smoke:fullstack": "bash scripts/smoke-fullstack.sh",
    "verify:deployed:api": "bash scripts/verify-deployed-api.sh",
    "capture:demo": "node scripts/capture-demo-assets.mjs",
    "sync:web-fixtures": "bash scripts/sync-web-fixtures.sh",
    "check:web-fixtures": "bash scripts/check-web-fixtures.sh",
    "check:db-codegen": "bash scripts/check-db-codegen.sh",
    "smoke:docker:api": "bash scripts/smoke-docker-api.sh",
    "test:e2e": "playwright test -c e2e/playwright.config.ts",
    "test:e2e:smoke": "playwright test -c e2e/playwright.config.ts e2e/demo-flow.spec.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "concurrently": "^9.2.4"
  }
}
