NODE_ENV=development
PORT=4000
WEB_ORIGIN=http://localhost:5173
DATABASE_URL=postgres://sitelens:sitelens@localhost:54329/sitelens
DB_SSL=false
REDIS_URL=redis://localhost:6389
CACHE_ENABLED=true
CACHE_DEFAULT_TTL_SECONDS=300
# Billing (Stripe-style, demo-safe). Leave secrets empty to run the demo flow.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
ENABLE_DEMO_BILLING=true
# Worldwide place search via Nominatim/OpenStreetMap backend proxy.
GEOCODING_ENABLED=true
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=SiteLens/0.1 (portfolio-demo; contact: replace-with-your-email@example.com)
GEOCODING_MIN_INTERVAL_MS=1100
GEOCODING_CACHE_TTL_SECONDS=86400
# Bundled static places when public Nominatim is blocked/unavailable (dev default on).
GEOCODING_STATIC_FALLBACK_ENABLED=true
GEOCODING_UPSTREAM_ERROR_COOLDOWN_MS=900000
GEOCODING_STATIC_FALLBACK_TTL_SECONDS=3600
