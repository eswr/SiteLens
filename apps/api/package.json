{
  "name": "@sitelens/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "test": "vitest run",
    "test:db": "RUN_DB_TESTS=true vitest run src/db",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:reset": "tsx src/db/reset.ts",
    "ingest:geojson": "tsx src/db/ingestGeojson.ts",
    "db:seed": "npm run ingest:geojson"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@sinclair/typebox": "^0.34.50",
    "@sitelens/shared": "*",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
