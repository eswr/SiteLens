{
  "name": "@sitelens/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "test": "vitest run",
    "test:db": "RUN_DB_TESTS=true vitest run src/db src/billing",
    "test:redis": "RUN_REDIS_TESTS=true vitest run src/cache src/providers",
    "test:geocoding:live": "RUN_GEOCODING_LIVE_TESTS=true vitest run src/geocoding/nominatimClient.live.test.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:check": "tsx src/db/migrate.ts --check",
    "db:migrate:prod": "node dist/db/migrate.js",
    "db:migrate:check:prod": "node dist/db/migrate.js --check",
    "db:reset": "tsx src/db/reset.ts",
    "ingest:geojson": "tsx src/db/ingestGeojson.ts",
    "ingest:geojson:prod": "node dist/db/ingestGeojson.js",
    "db:seed:billing": "tsx src/db/seedBilling.ts",
    "db:seed:billing:prod": "node dist/db/seedBilling.js",
    "db:seed": "npm run ingest:geojson && npm run db:seed:billing",
    "cache:clear": "tsx src/cache/clearCache.ts",
    "cache:clear:prod": "node dist/cache/clearCache.js",
    "worker:planning-context": "tsx src/worker/planningContextWorkerMain.ts",
    "worker:planning-context:prod": "node dist/worker/planningContextWorkerMain.js",
    "db:codegen": "pgtyped -c pgtyped.json"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@pgtyped/runtime": "^2.4.2",
    "@sinclair/typebox": "^0.34.50",
    "@sitelens/shared": "*",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0",
    "pg-boss": "^10.4.2"
  },
  "devDependencies": {
    "@pgtyped/cli": "^2.4.3",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
