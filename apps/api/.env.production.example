# Production / deployed API reference (Fly secrets + local verify script).
# Copy to apps/api/.env.production — never commit real DB/Redis secrets.
# On Fly, prefer `fly secrets set` over baking secrets into this file.
NODE_ENV=production
PORT=4000
WEB_ORIGIN=https://sitelens-demo.vercel.app

DATABASE_URL=<neon-postgres-url>
DB_SSL=true

# Fly-private Upstash host resolves only on Fly machines (not your laptop).
REDIS_URL=<upstash-redis-url-from-fly-redis-create>
CACHE_ENABLED=true
CACHE_DEFAULT_TTL_SECONDS=300

ENABLE_DEMO_BILLING=true

GEOCODING_ENABLED=true
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=SiteLens/0.1 (portfolio-demo; contact: easwarendra.ece@gmail.com)
GEOCODING_MIN_INTERVAL_MS=1100
GEOCODING_CACHE_TTL_SECONDS=86400
GEOCODING_STATIC_FALLBACK_ENABLED=true
GEOCODING_UPSTREAM_ERROR_COOLDOWN_MS=900000
GEOCODING_STATIC_FALLBACK_TTL_SECONDS=3600

# External planning context via Overpass (backend-only; never called from the browser).
OVERPASS_ENABLED=true
OVERPASS_BASE_URL=https://overpass-api.de/api/interpreter
OVERPASS_USER_AGENT=SiteLens/0.1 (portfolio-demo; contact: you@example.com)
OVERPASS_TIMEOUT_MS=15000
OVERPASS_MIN_INTERVAL_MS=2500
EXTERNAL_CONTEXT_CACHE_TTL_SECONDS=604800
EXTERNAL_CONTEXT_MAX_BBOX_AREA_DEG2=0.01
EXTERNAL_CONTEXT_REBUILD_AFTER_DAYS=7

# In-process async planning-context build worker (demo job queue).
PLANNING_CONTEXT_WORKER_ENABLED=true
PLANNING_CONTEXT_WORKER_POLL_MS=750
PLANNING_CONTEXT_JOB_LOCK_MS=300000
PLANNING_CONTEXT_JOB_MAX_ATTEMPTS=3

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Used by scripts/verify-deployed-api.sh (not by the API process).
API_BASE=https://sitelens-api.fly.dev
