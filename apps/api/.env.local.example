# Local API development (Docker PostGIS :54329 + Redis :6389).
# Copy to apps/api/.env.local — never commit .env.local.
NODE_ENV=development
PORT=4000
WEB_ORIGIN=http://localhost:5173
DATABASE_URL=postgres://sitelens:sitelens@localhost:54329/sitelens
DB_SSL=false
REDIS_URL=redis://localhost:6389
CACHE_ENABLED=true
CACHE_DEFAULT_TTL_SECONDS=300
# Outbound Nominatim/Overpass spacers: auto|redis|memory (auto uses Redis when ready).
PROVIDER_RATE_LIMIT_BACKEND=auto
PROVIDER_COOLDOWN_TTL_MS=60000
PROVIDER_RATE_LIMIT_NAMESPACE=sitelens:provider-limits:v1
# Billing (Stripe-style, demo-safe). Leave secrets empty to run the demo flow.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
ENABLE_DEMO_BILLING=true
# Worldwide place search via Nominatim/OpenStreetMap backend proxy.
GEOCODING_ENABLED=true
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=SiteLens/0.1 (portfolio-demo; contact: replace-with-your-email@example.com)
GEOCODING_MIN_INTERVAL_MS=1100
GEOCODING_CACHE_TTL_SECONDS=86400
# Bundled static places when public Nominatim is blocked/unavailable (dev default on).
GEOCODING_STATIC_FALLBACK_ENABLED=true
GEOCODING_UPSTREAM_ERROR_COOLDOWN_MS=900000
GEOCODING_STATIC_FALLBACK_TTL_SECONDS=3600
# External planning context via Overpass (backend-only; never called from the browser).
OVERPASS_ENABLED=true
OVERPASS_BASE_URL=https://overpass-api.de/api/interpreter
OVERPASS_USER_AGENT=SiteLens/0.1 (portfolio-demo; contact: replace-with-your-email@example.com)
OVERPASS_TIMEOUT_MS=15000
OVERPASS_MIN_INTERVAL_MS=2500
EXTERNAL_CONTEXT_CACHE_TTL_SECONDS=604800
EXTERNAL_CONTEXT_MAX_BBOX_AREA_DEG2=0.01
EXTERNAL_CONTEXT_REBUILD_AFTER_DAYS=7
EXTERNAL_CONTEXT_SYNTHETIC_FALLBACK_ENABLED=false
# Planning-context worker: in-process (local demo) | pg-boss | disabled.
# Legacy PLANNING_CONTEXT_WORKER_ENABLED=false maps to disabled when MODE is unset.
PLANNING_CONTEXT_WORKER_MODE=in-process
PLANNING_CONTEXT_WORKER_ENABLED=true
PLANNING_CONTEXT_WORKER_POLL_MS=750
PLANNING_CONTEXT_JOB_LOCK_MS=300000
PLANNING_CONTEXT_JOB_MAX_ATTEMPTS=3
PG_BOSS_SCHEMA=pgboss
PG_BOSS_QUEUE_PLANNING_CONTEXT=planning-context-build
PG_BOSS_WORKER_CONCURRENCY=1
PG_BOSS_POLL_INTERVAL_MS=1000
